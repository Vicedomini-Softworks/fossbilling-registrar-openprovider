{
    "name": "vicedomini-softworks/fossbilling-registrar-openprovider",
    "description": "OpenProvider domain registrar adapter for FOSSBilling",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^7.0"
    },
    "autoload": {
        "classmap": [
            "library/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/Stubs/"
        ],
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
